# ─── Quorex Memory Engine (FastAPI) ──────────────────────────────────────────

# Shared secret between the Node backend and the engine. MUST match
# QUOREX_INTERNAL_KEY in quorex-web/server/.env. Used by the X-Quorex-Internal-Key
# header guard on all /memory/* endpoints.
QUOREX_INTERNAL_KEY=53fc3abf636a34e8c57732a9e5520b8249f1df7218ea3bbaf394e3c18375c7c

# Where the engine persists WAL + snapshots and the saved encoder.
QUOREX_DB_PATH=/data/quorex_memory
QUOREX_ENCODER_PATH=/data/quorex_encoder

# Embedding dimensionality (optional, defaults to 32).
# QUOREX_DIMS=32

# Optional. The engine itself does NOT talk to PostgreSQL in the current
# architecture (API-key auth + logging live in the Node backend), so this is
# only needed if you later move SDK auth into the engine.
DATABASE_URL=postgresql://user:password@host:5432/dbname
